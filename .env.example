# Runtime settings (set these in Railway service Variables)
OPENCLAW_GATEWAY_PORT=8080
# Railway Template Composer: set OPENCLAW_GATEWAY_TOKEN to
# ${{secret(64, "abcdef0123456789")}} to auto-generate a random token per deploy.
OPENCLAW_GATEWAY_TOKEN=change-me
OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace
OPENCLAW_CONFIG_PATH=/data/.openclaw/openclaw.json
OPENCLAW_PLUGIN_STAGE_DIR=/data/plugin-runtime-deps
OPENCLAW_DISABLE_BONJOUR=1

# Optional: comma-separated allowed origins for Control UI (custom domains).
# Recommended format: https://your-domain (no path). Domains and ws/wss URLs are normalized.
# If empty, startup auto-uses https://${RAILWAY_PUBLIC_DOMAIN} when available.
OPENCLAW_CONTROL_UI_ALLOWED_ORIGINS=

# Optional Tailscale settings
TAILSCALE_AUTHKEY=
TAILSCALE_HOSTNAME=openclaw-railway

# Optional timezone
OPENCLAW_TZ=UTC
